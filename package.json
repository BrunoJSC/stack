{
  "name": "stack",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "elysia": "^1.4.28",
      "@trpc/server": "^11.16.0",
      "better-auth": "1.6.11",
      "evlog": "^2.18.1",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "sonner": "^2.0.5",
      "@trpc/tanstack-react-query": "^11.16.0",
      "@trpc/client": "^11.16.0",
      "@tanstack/react-form": "^1.28.0",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18",
      "@better-auth/expo": "1.6.11",
      "drizzle-orm": "^0.45.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @stack/db db:push",
    "db:studio": "turbo -F @stack/db db:studio",
    "db:generate": "turbo -F @stack/db db:generate",
    "db:migrate": "turbo -F @stack/db db:migrate",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@stack/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@stack/config": "workspace:*",
    "@types/bun": "catalog:",
    "husky": "latest",
    "turbo": "^2.9.16",
    "typescript": "catalog:",
    "ultracite": "7.8.3"
  },
  "packageManager": "bun@1.3.14"
}
